# ─── Server ──────────────────────────────────────────────
PORT=3000

# ─── Twilio ───────────────────────────────────────────────
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# The Twilio number Cove answers on (E.164 format)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── User ─────────────────────────────────────────────────
# Your real personal phone number Cove forwards trusted calls to
USER_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Retell AI ────────────────────────────────────────────
# Your Retell API key
RETELL_API_KEY=your_retell_api_key
# The Retell agent ID to use for screening calls
RETELL_AGENT_ID=your_retell_agent_id

# ─── Supabase ─────────────────────────────────────────────
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# Service role key (keep secret — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
