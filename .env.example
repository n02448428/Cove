# ================================================================
# COVE MVP - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================================

# ---- Frontend (Vite) -------------------------------------------
# Supabase project URL
VITE_SUPABASE_URL=https://csbstpehuunaoyehhixp.supabase.co

# Supabase publishable (anon) key - safe to expose in browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Backend / Edge Functions ----------------------------------
# Supabase service role key - NEVER expose publicly
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase URL (same as above, used in Edge Functions)
SUPABASE_URL=https://csbstpehuunaoyehhixp.supabase.co

# ---- Twilio ----------------------------------------------------
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# The Twilio number Cove answers on (E.164 format, auto-assigned per user)
# This is stored per-user in the database - not a single global number
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ---- Retell AI -------------------------------------------------
# Your Retell API key
RETELL_API_KEY=your_retell_api_key

# Your Retell agent ID (Concierge MVP agent)
RETELL_AGENT_ID=your_retell_agent_id

# ---- Resend (Email notifications) ------------------------------
# Your Resend API key
RESEND_API_KEY=your_resend_api_key

# ---- App -------------------------------------------------------
# Base URL of your deployed app (used in webhook callbacks)
# Development: http://localhost:54321 (Supabase local functions)
# Production: https://csbstpehuunaoyehhixp.supabase.co
APP_BASE_URL=https://csbstpehuunaoyehhixp.supabase.co

# ---- Local dev server ------------------------------------------
PORT=5173
