# ================================================================
# COVE MVP - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# Hosted on GitHub Pages: https://n02448428.github.io/Cove
# ================================================================

# ---- Frontend (Vite) -------------------------------------------
# Supabase project URL
VITE_SUPABASE_URL=https://csbstpehuunaoyehhixp.supabase.co

# Supabase publishable (anon) key - safe to expose in browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Backend / Edge Functions ----------------------------------
# Supabase service role key - NEVER expose publicly
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase URL (same as above, used in Edge Functions)
SUPABASE_URL=https://csbstpehuunaoyehhixp.supabase.co

# ---- Twilio ----------------------------------------------------
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# The Twilio number used for SMS notifications (E.164 format)
# Note: concierge numbers are auto-assigned per user and stored in DB
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ---- Retell AI -------------------------------------------------
# Your Retell API key
RETELL_API_KEY=your_retell_api_key

# Your Retell agent ID (Concierge MVP agent)
RETELL_AGENT_ID=your_retell_agent_id

# ---- Resend (Email notifications) ------------------------------
# Your Resend API key
RESEND_API_KEY=your_resend_api_key

# ---- App -------------------------------------------------------
# Base URL used in Edge Function webhook callbacks
# Production (GH Pages frontend + Supabase Edge Functions):
APP_BASE_URL=https://csbstpehuunaoyehhixp.supabase.co
# Local dev (Supabase local):
# APP_BASE_URL=http://localhost:54321

# ---- Local dev server ------------------------------------------
PORT=5173
